# ═══════════════════════════════════════════════
# 🤖 RESBOT TELEGRAM - Environment Configuration
# ═══════════════════════════════════════════════

# Bot Token dari @BotFather di Telegram
BOT_TOKEN=your_bot_token_here

# Mode: polling atau webhook
BOT_MODE=polling

# Webhook (opsional, hanya jika BOT_MODE=webhook)
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_PORT=3000

# API Key untuk layanan eksternal (autoresbot.com)
APIKEY=your_apikey_here
